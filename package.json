{
	"name": "strong-towns-carmel-website",
	"version": "0.0.2",
	"description": "Website for the local chapter of Strong Towns in Carmel, Indiana.",
	"type": "module",
	"scripts": {
		"build": "npx @11ty/eleventy",
		"build-nocolor": "cross-env NODE_DISABLE_COLORS=1 npx @11ty/eleventy",
		"build-ghpages": "npx @11ty/eleventy --pathprefix=/eleventy-base-blog/",
		"start": "npx @11ty/eleventy --serve --quiet",
		"start-ghpages": "npx @11ty/eleventy --pathprefix=/eleventy-base-blog/ --serve --quiet",
		"debug": "cross-env DEBUG=Eleventy* npx @11ty/eleventy",
		"debugstart": "cross-env DEBUG=Eleventy* npx @11ty/eleventy --serve --quiet",
		"benchmark": "cross-env DEBUG=Eleventy:Benchmark* npx @11ty/eleventy",
		"new-post": "node ./scripts/new-post.js"
	},
	"repository": {
		"type": "git",
		"url": "git://github.com/simpixelated/strongtownscarmel.git"
	},
	"author": {
		"name": "Jordan Kohl",
		"email": "kohl.jordan@gmail.com",
		"url": "https://strongtownscarmel.org/"
	},
	"license": "MIT",
	"engines": {
		"node": ">=18"
	},
	"bugs": {
		"url": "https://github.com/simpixelated/strongtownscarmel/issues"
	},
	"homepage": "https://github.com/simpixelated/strongtownscarmel#readme",
	"devDependencies": {
		"@11ty/eleventy": "^3.1.0",
		"@11ty/eleventy-img": "^6.0.1",
		"@11ty/eleventy-navigation": "^0.3.5",
		"@11ty/eleventy-plugin-rss": "^2.0.2",
		"@11ty/eleventy-plugin-syntaxhighlight": "^5.0.0",
		"@11ty/font-awesome": "^1.0.0-beta.1",
		"cross-env": "^7.0.3",
		"luxon": "^3.5.0",
		"prismjs": "^1.29.0",
		"zod": "^3.23.8",
		"zod-validation-error": "^3.3.1"
	},
	"dependencies": {
		"@zachleat/heading-anchors": "^1.0.1"
	}
}
