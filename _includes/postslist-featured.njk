<div class="container post-list-featured">
  {%- for post in postslist | reverse %}
    {%- if loop.first %}
    <div class="p-4 p-md-5 mb-4 rounded text-body-emphasis bg-body-secondary">
      <div class="row">
        <div class="col-lg-6 px-0">
          <h3 class="display-5 fst-italic">{{post.data.title}}</h3>
          <p class="lead my-3">{{post.data.intro}}</p>
          <p class="lead mb-0">
            <a href="{{post.url}}" class="text-body-emphasis fw-bold">Continue reading...</a>
          </p>
        </div>
        <div class="col-lg-6 px-0">
          <img
            src="{{post.url}}/{{post.data.featuredimage}}"
            class="img-fluid rounded"
            alt="Strong Towns Carmel">
        </div>
      </div>
    </div>
    {% else %}
    {% if loop.index == 2 %}<div class="row">{% endif %}
      <div class="col-md-6">
        <div class="row g-0 border rounded overflow-hidden flex-md-row mb-4 shadow-sm h-md-250 position-relative">
          <div class="col p-4 d-flex flex-column position-static">
            <strong class="d-inline-block mb-2 text-primary-emphasis">World</strong>
            <h3 class="mb-0">{{post.data.title}}</h3>
            <time class="mb-1 text-body-secondary" datetime="{{ post.date | htmlDateString }}">{{ post.date | readableDate("LLLL yyyy") }}</time>
            <p class="card-text mb-auto">{{post.data.intro}}</p>
            <a href="{{post.url}}" class="icon-link gap-1 icon-link-hover stretched-link">
              Continue reading
              <svg class="bi" aria-hidden="true">
                <use xlink:href="#chevron-right"></use>
              </svg>
            </a>
          </div>
          <div class="col-auto d-none d-lg-block">
            <svg
              aria-label="Placeholder: Thumbnail"
              class="bd-placeholder-img "
              height="250"
              preserveaspectratio="xMidYMid slice"
              role="img"
              width="200"
              xmlns="http://www.w3.org/2000/svg">
              <title>Placeholder</title>
              <rect width="100%" height="100%" fill="#55595c"></rect>
              <text x="50%" y="50%" fill="#eceeef" dy=".3em">Thumbnail</text>
            </svg>
          </div>
        </div>
      </div>
      {%- endif %}
    {%- endfor %}
    </div>
  </div>
</div>
