---js
const eleventyNavigation = {
	key: "Events",
	order: 3
};
const layout = 'layouts/page.njk';
const title = 'Events';
---

<h1>Events</h1>

<h2>Upcoming Events</h2>
{%- set eventPosts = collections.events | upcomingEvents -%}
{%- if eventPosts.length > 0 -%}
{%- for post in eventPosts -%}
<div class="card mb-3">
  <div class="card-body">
    <h5 class="card-title">{{ post.data.title }}</h5>
    <p class="card-text">{{ post.data.intro }}</p>
    <a href="{{ post.url }}" class="btn btn-primary">Details &amp; RSVP</a>
  </div>
</div>
{%- endfor -%}
{%- else -%}
<p>No upcoming events at this time. Check back soon!</p>
{%- endif -%}

<hr>

<h2>Past Events</h2>

{%- set pastEventPosts = collections.events | pastEvents -%}
{%- if pastEventPosts.length > 0 -%}
<ul>
{%- for post in pastEventPosts -%}
  <li><a href="{{ post.url }}">{{ post.data.title }}</a></li>
{%- endfor -%}
</ul>
{%- else -%}
<p>No past events yet.</p>
{%- endif -%}