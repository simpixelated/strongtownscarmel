---js
const eleventyNavigation = {
	key: "Blog",
	order: 3
};
const title = "Blog";
const layout = 'layouts/page.njk';
---
<div class="row align-items-center mb-4">
	<div class="col">
		<h1>Blog</h1>
	</div>
	<div class="col-auto">
		<a href="/tags/">View all tags</a>
	</div>
</div>

{% for year, posts in collections.posts | groupby("date") | dictsort | reverse %}
<h4>{{ year }}</h4>
<ul>
	{% for post in posts | reverse %}
	{% set tags = post.data.tags | exclude('posts') %}
	<li>
		<a href="{{ post.url }}" class="blog-post-title">{{ post.data.title }}</a><br />
		<small class="post-meta"><time>{{ post.date | postDate }}</time>{% if tags | length %} - {% include "tag-list.njk" %}{% endif %}</small>
	</li>
	{% endfor %}
</ul>
{% endfor %}
